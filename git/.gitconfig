[user]
	name = npikall
	email = nikolas.pikall@gmail.com
[init]
	default = master
	defaultbranch = master
[core]
	editor = nvim
[gpg]
	format = ssh
[commit]
	gpgsign = true
[merge]
	tool = nvimdiff3
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[pull]
	rebase = true
